# OcchioEsperto.it — Configurazione ambiente
# Copia in .env e modifica i valori per il deploy in produzione

# --- Security ---
# Genera una chiave segreta con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# --- Stripe (per pagamenti) ---
# Inserisci le tue chiavi API Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Prezzi Stripe (opzionale: se usi predefiniti, lascia i placeholder)
STRIPE_PRICE_4_99=price_intermedio
STRIPE_PRICE_9_99=price_avanzato