# OcchioEsperto.it — Configurazione ambiente
# Copia in .env e modifica i valori per il deploy in produzione

# --- Security ---
# Genera una chiave segreta con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# --- Stripe (per pagamenti) ---
# Inserisci le tue chiavi API Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Prezzi Stripe (opzionale: se usi predefiniti, lascia i placeholder)
STRIPE_PRICE_4_99=price_intermedio
STRIPE_PRICE_9_99=price_avanzato

# --- OpenRouter AI ---
# Chiave lato server; non inserirla mai nel frontend.
OPENROUTER_API_KEY=
# Prima scansione: usa un modello OpenRouter gratuito o molto economico.
OPENROUTER_MODEL_FREE=
AI_MODEL_FREE_FALLBACKS=
# Analisi Intermedio/Avanzato: usa i migliori modelli disponibili, separati da virgola.
OPENROUTER_MODELS_PREMIUM=
AI_MODEL_PREMIUM_FALLBACKS=
# Compatibilità/fallback generale.
OPENROUTER_MODEL=
AI_MODEL_FALLBACKS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_SITE_URL=https://occhioesperto.it
AI_APP_NAME=OcchioEsperto.it