# OcchioEsperto.it — Configurazione ambiente
# Copia in .env e modifica i valori prima del deploy in produzione.

# --- Security ---
# Genera: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-64-char-secret
PUBLIC_SITE_URL=https://occhioesperto.it

# --- Frontend/API ---
# Lascia vuoto in Docker/same-origin. In sviluppo separato puoi usare: VITE_API_BASE_URL=http://127.0.0.1:3000/api
VITE_API_BASE_URL=

# --- AI / OpenRouter ---
# Consigliato: usa OpenRouter per fallback automatico multi-modello.
# Grok/xAI è volutamente ultimo nella lista.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_FALLBACKS=openai/gpt-4.1-mini,anthropic/claude-3.5-sonnet,google/gemini-2.0-flash-001,x-ai/grok-3-mini
AI_REQUEST_TIMEOUT_SECONDS=45
MAX_UPLOAD_MB=10

# --- Stripe (pagamenti) ---
# Lascia vuoto in staging se vuoi testare solo il prodotto senza checkout reale.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_4_99=price_intermedio
STRIPE_PRICE_9_99=price_avanzato
